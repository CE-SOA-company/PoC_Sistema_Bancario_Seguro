{
  "openapi": "3.1.0",
  "info": {
    "title": "SecureBankito Bank Service",
    "version": "0.1.0"
  },
  "paths": {
    "/bank/deposit": {
      "post": {
        "tags": [
          "bank"
        ],
        "summary": "Depositar en cuenta",
        "description": "Lee integrity_level desde el JWT Bearer token y aplica Biba — No Write Up dentro del Aggregate Root CuentaBancaria: un proceso con integridad inferior a la requerida por la cuenta recibe 403 Forbidden.",
        "operationId": "deposit_bank_deposit_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DepositRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Check Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DepositRequest": {
        "properties": {
          "account_id": {
            "type": "string",
            "title": "Account Id",
            "description": "Identificador de la cuenta",
            "examples": [
              "gold-001"
            ]
          },
          "amount": {
            "type": "number",
            "exclusiveMinimum": 0,
            "title": "Amount",
            "description": "Monto a depositar",
            "examples": [50]
          }
        },
        "type": "object",
        "required": [
          "account_id",
          "amount"
        ],
        "title": "DepositRequest",
        "description": "Modelo de solicitud para depositar en una cuenta bancaria.",
        "examples":[{
          "account_id": "gold-001",
          "amount": 50
        }] 
      },
      "DepositResponse": {
        "properties": {
          "transaction_id": {
            "type": "string",
            "title": "Transaction Id",
            "description": "Identificador único de la transacción"
          },
          "account_id": {
            "type": "string",
            "title": "Account Id",
            "description": "Cuenta afectada"
          },
          "amount": {
            "type": "number",
            "title": "Amount",
            "description": "Monto depositado"
          },
          "actor_integrity_level": {
            "type": "integer",
            "title": "Actor Integrity Level",
            "description": "Integridad usada en la validación Biba"
          }
        },
        "type": "object",
        "required": [
          "transaction_id",
          "account_id",
          "amount",
          "actor_integrity_level"
        ],
        "title": "DepositResponse",
        "description": "Modelo de respuesta para la operación de depósito."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}