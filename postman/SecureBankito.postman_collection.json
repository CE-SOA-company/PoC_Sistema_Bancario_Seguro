{
  "info": {
    "_postman_id": "3d0c9f6b-5b6e-4ce4-b3d1-6e4c4e8a7f10",
    "name": "SecureBankito API Demo",
    "description": "Collection de pruebas para Swagger/Postman de la PoC SecureBankito.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "IAM",
      "item": [
        {
          "name": "Login admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{iamBaseUrl}}/auth/login",
              "host": [
                "{{iamBaseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "description": "Obtiene un JWT con clearance_level e integrity_level."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Returns access token', function () {",
                  "  pm.expect(body).to.have.property('access_token');",
                  "});",
                  "pm.environment.set('accessToken', body.access_token);"
                ]
              }
            }
          ]
            },
            {
              "name": "Login bronze",
