                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () {",
                  "  pm.response.to.have.status(403);",
                  "});",
                  "pm.test('No Read Up message', function () {",
                  "  pm.expect(pm.response.text()).to.include('No Read Up');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
