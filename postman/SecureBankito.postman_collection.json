    },
    {
      "name": "Bank",
      "item": [
        {
          "name": "Deposit allowed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{bankBaseUrl}}/bank/deposit",
              "host": [
                "{{bankBaseUrl}}"
              ],
              "path": [
                "bank",
                "deposit"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_id\": \"gold-001\",\n  \"amount\": 50.0\n}"
            },
            "description": "Escenario exitoso: el JWT del login aporta la integridad requerida para escribir."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Contains transaction id', function () {",
                  "  pm.expect(pm.response.json()).to.have.property('transaction_id');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Deposit forbidden - Biba",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{bronzeToken}}"
              }
            ],
            "url": {
              "raw": "{{bankBaseUrl}}/bank/deposit",
              "host": [
                "{{bankBaseUrl}}"
              ],
              "path": [
                "bank",
                "deposit"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_id\": \"gold-001\",\n  \"amount\": 25.0\n}"
            },
            "description": "Escenario de defensa: la integridad viene del JWT; si es insuficiente, el servicio responde 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', function () {",
                  "  pm.response.to.have.status(403);",
                  "});",
                  "pm.test('No Write Up message', function () {",
                  "  pm.expect(pm.response.text()).to.include('No Write Up');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Investment",
      "item": [
        {
          "name": "List assets allowed",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{investmentBaseUrl}}/investments/assets",
              "host": [
                "{{investmentBaseUrl}}"
              ],
              "path": [
                "investments",
                "assets"
              ]
            },
            "description": "Escenario exitoso: el JWT del login aporta el clearance requerido para listar activos."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns a list', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
